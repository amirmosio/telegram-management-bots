[Unit]
Description=Music recognition service (ShazamIO backend)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=azureuser
Group=azureuser
WorkingDirectory=/home/azureuser/telegram-management-bots/tasks/music_player_app
Environment=PYTHONUNBUFFERED=1
ExecStart=/home/azureuser/telegram-management-bots/tasks/music_player_app/recognize_venv/bin/python recognize_server.py
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
